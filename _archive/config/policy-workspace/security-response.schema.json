{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision", "reason"],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["allow", "block"]
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    }
  }
}
